---
import BaseLayout from "@/layouts/BaseLayout.astro";

import heroWorker from "../assets/images/hero_worker.png";
import serviceGutter from "../assets/images/service_gutter.png";
import serviceRoofInstall from "../assets/images/service_roof_install.png";
import serviceRoofRepair from "../assets/images/service_roof_repair.png";
import serviceRoofReplace from "../assets/images/service_roof_replace.png";
import serviceSiding from "../assets/images/service_siding.png";

import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query, sortByOrder } from "@/utils/query";
import Button from "@/components/Button/Button";
import PhoneLink from "@/components/PhoneLink.astro";
import BackgroundMedia from "@/components/BackgroundMedia.astro";
import GoogleRating from "@/components/GoogleRating.astro";
import AboutIntro from "@/components/AboutIntro.astro";
import { getServiceAreaNames } from "@/utils/serviceAreas";

// Top 4 selling points for the "Why Choose Us" benefits list
const whyChoosePoints = (
  await query("selling-points").orderBy(sortByOrder()).all()
).slice(0, 4);

// Service-area states (single source of truth) → full-name label for copy.
const serviceAreaLabel = await getServiceAreaNames();
---

<BaseLayout
  title="Professional Roofing Services"
  description="Professional roofing services in Somerset, New Jersey. Free estimates, 0% financing available, roof repairs, replacements, and commercial roofing."
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&family=Saira+Condensed:ital,wght@1,700;1,800&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <main class="flex-1">
    <section class="hero" id="hero">
      <BackgroundMedia
        backgroundMedia={{
          image: { src: heroWorker, aboveTheFold: true },
          video: {
            src: "/hero.mp4",
            autoPlay: true,
            muted: true,
            loop: true,
            playsInline: true,
            controls: false,
            preload: "metadata",
          },
        }}
      />
      <div class="absolute inset-0 z-[1] bg-[linear-gradient(180deg,rgba(15,23,42,0.8)_0%,rgba(15,23,42,0.85)_60%,rgba(15,23,42,0.92)_100%)]"></div>
      <div class="container relative z-[2] flex justify-center">
        <div class="flex flex-col items-center text-center max-w-[900px]">
          <h1 class="font-['Saira_Condensed'] font-extrabold italic leading-[0.9] mb-4 tracking-normal uppercase text-white [text-shadow:0_2px_20px_rgba(0,0,0,0.35)]">
            <span class="hero-title-top">John's Pro</span>
            <span class="hero-title-bottom not-italic">Roofing</span>
          </h1>
          <p class="hero-subtitle">
            Free estimates, 0% financing available, and dependable roofing work from a local team you can count on.
          </p>
          <div class="flex flex-wrap justify-center gap-4 py-6">
            <Button variant="primary" size="lg" href="/contact-us">
              Request an Estimate
            </Button>
            <PhoneLink variant="phone" tone="white" size="lg" />
          </div>

          <a
            href="/testimonials"
            class="inline-flex items-center gap-3"
            aria-label="Rated 4.7 out of 5 from 20 Google reviews"
          >
            <span class="text-sm font-medium text-white/75 leading-none whitespace-nowrap">20 Reviews</span>
            <svg class="w-[22px] h-[22px] shrink-0" viewBox="0 0 24 24" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.76h3.56c2.08-1.92 3.28-4.74 3.28-8.09Z" />
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.76c-.98.66-2.23 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z" />
              <path fill="#FBBC05" d="M5.84 14.11a6.6 6.6 0 0 1 0-4.22V7.05H2.18a11 11 0 0 0 0 9.9l3.66-2.84Z" />
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.05l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38Z" />
            </svg>
            <span class="inline-flex gap-0.5 text-[#fbbc05] text-[15px] leading-none" aria-hidden="true">
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
            </span>
            <span class="font-['Saira_Condensed'] font-bold text-base text-white leading-none">4.7</span>
          </a>
        </div>
      </div>
    </section>

    <ContentRenderer
      query={query("selling-points").orderBy(sortByOrder())}
      variant="MarqueeVariant"
    />

    <section class="about-section" id="about">
      <div class="container">
        <AboutIntro reverse={true} />
      </div>
    </section>

    {/* Roofing pointers — heading left, copy + stats right (Axel's-style) */}
    <section class="py-[100px] bg-[var(--color-canvas-secondary)]" id="why-us">
      <div class="container">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          {/* Heading */}
          <div>
            <span class="section-pretitle">The John's Pro Difference</span>
            <h2 class="section-title !text-[clamp(36px,5vw,56px)] leading-[1.05]">
              Roofs that last,
              <span class="not-italic font-[family-name:var(--font-body)] text-accent"> done right, </span>
              the first time.
            </h2>
          </div>

          {/* Copy + stats */}
          <div>
            <p class="text-[var(--color-text-body)] text-base leading-[1.8] mb-5">
              We don't cut corners. Every job gets a thorough inspection, honest recommendations, and quality materials installed by a crew that treats your home like their own — no subs, no surprises.
            </p>
            <p class="text-[var(--color-text-body)] text-base leading-[1.8] mb-8">
              From storm-damage repairs to full replacements, we back our work with a 25-year workmanship warranty and a satisfaction guarantee. If it's not right, we make it right.
            </p>

            <div class="border-t border-[var(--color-border)] pt-8 grid grid-cols-3 gap-6">
              <div>
                <div class="text-[clamp(28px,3vw,38px)] font-extrabold text-accent leading-none">500+</div>
                <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] mt-2">Roofs Installed</div>
              </div>
              <div>
                <div class="text-[clamp(28px,3vw,38px)] font-extrabold text-accent leading-none">25-Yr</div>
                <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] mt-2">Workmanship Warranty</div>
              </div>
              <div>
                <div class="text-[clamp(28px,3vw,38px)] font-extrabold text-accent leading-none">0%</div>
                <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] mt-2">Financing Available</div>
              </div>
            </div>

            <div class="mt-8">
              <Button variant="secondary" size="lg" href="/about-us">Our Story</Button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="projects">
      <ContentRenderer
        query={query("projects")
          .where((entry) => Boolean(entry.data.beforeImage && entry.data.afterImage))
          .orderBy(sortByOrder())}
        variant="BeforeAfterVariant"
        pretitle="Recent Projects"
        title="Real Homes."
        accentTitle="Real Work."
        description={`A look at recent roofing transformations across ${serviceAreaLabel}.`}
        dark={true}
        columns={2}
        showButtonSection={false}
      />
    </section>

    <section class="bg-[var(--color-canvas-secondary)] py-[100px] border-t border-[var(--color-border)]" id="services">
      <div class="container">
        <div class="section-header">
          <span class="section-pretitle">Professional Roofing & Decking</span>
          <h2 class="section-title">Free Estimate Financing Available</h2>
          <p class="section-description">
            We provide residential roofing, commercial roofing, flat roof expertise, and custom decking services with premium materials and a straightforward process.
          </p>
        </div>

        <div class="services-grid">
          {/* Residential Roofing */}
          <div class="service-card">
            <div class="card-image-container">
              <img
                src={serviceRoofInstall.src}
                alt="Residential Roofing Service"
                class="card-image"
              />
              <div class="card-badge">Premium</div>
            </div>
            <div class="card-content">
              <h3 class="card-title">Residential Roofing</h3>
              <p class="card-text">
                Full residential roofing services built for lasting protection and clean, dependable results.
              </p>
              <a href="#quote-form" class="card-link">
                Learn More <i class="fa-solid fa-arrow-right-long"></i>
              </a>
            </div>
          </div>

          {/* Commercial Roofing */}
          <div class="service-card">
            <div class="card-image-container">
              <img
                src={serviceRoofReplace.src}
                alt="Commercial Roofing Service"
                class="card-image"
              />
              <div class="card-badge">Certified</div>
            </div>
            <div class="card-content">
              <h3 class="card-title">Commercial Roofing</h3>
              <p class="card-text">
                Commercial roof replacement and repair work completed with quality materials and careful attention to detail.
              </p>
              <a href="#quote-form" class="card-link">
                Learn More <i class="fa-solid fa-arrow-right-long"></i>
              </a>
            </div>
          </div>

          {/* Flat Roof Experts */}
          <div class="service-card">
            <div class="card-image-container">
              <img
                src={serviceRoofRepair.src}
                alt="Flat Roof Experts"
                class="card-image"
              />
              <div class="card-badge">Expert Solutions</div>
            </div>
            <div class="card-content">
              <h3 class="card-title">Flat Roof Experts</h3>
              <p class="card-text">
                Specialized flat roof installations, durable silicone coatings, and expert repairs for residential and commercial properties.
              </p>
              <a href="#quote-form" class="card-link">
                Learn More <i class="fa-solid fa-arrow-right-long"></i>
              </a>
            </div>
          </div>

          {/* Roof Repair */}
          <div class="service-card">
            <div class="card-image-container">
              <img
                src={serviceRoofRepair.src}
                alt="Roof Repair Service"
                class="card-image"
              />
              <div class="card-badge">24/7 Support</div>
            </div>
            <div class="card-content">
              <h3 class="card-title">Roof Repair</h3>
              <p class="card-text">
                Fast repair service for leaks, storm damage, missing shingles, and flashing issues.
              </p>
              <a href="#quote-form" class="card-link">
                Learn More <i class="fa-solid fa-arrow-right-long"></i>
              </a>
            </div>
          </div>

          {/* Deck Installation */}
          <div class="service-card">
            <div class="card-image-container">
              <img
                src={serviceSiding.src}
                alt="Deck Installation Service"
                class="card-image"
              />
            </div>
            <div class="card-content">
              <h3 class="card-title">Deck Installation</h3>
              <p class="card-text">
                Custom deck builds that create durable outdoor living space.
              </p>
              <a href="#quote-form" class="card-link">
                Learn More <i class="fa-solid fa-arrow-right-long"></i>
              </a>
            </div>
          </div>

          {/* Deck Repair */}
          <div class="service-card">
            <div class="card-image-container">
              <img
                src={serviceGutter.src}
                alt="Deck Repair Service"
                class="card-image"
              />
            </div>
            <div class="card-content">
              <h3 class="card-title">Deck Repair</h3>
              <p class="card-text">
                Repair loose boards, weather damage, and structural wear on existing decks.
              </p>
              <a href="#quote-form" class="card-link">
                Learn More <i class="fa-solid fa-arrow-right-long"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div id="testimonials" class="pt-[100px]">

      <ContentRenderer
        query={query("testimonials").orderBy(sortByOrder())}
        variant="TestimonialCarouselVariant"
        collectionUrl="/testimonials"
        collectionTitle="Reviews"
      />
    </div>

    {/* CTA banner — replaces the contact form (form commented out below) */}
    {/* Bottom CTA — photo bg with red gradient (opaque left → transparent right) */}
    <section class="relative overflow-hidden" id="quote-form">
      {/* Background photo */}
      <img
        src={serviceRoofRepair.src}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover"
      />
      {/* Red gradient overlay: opaque on the left, fading to transparent on the right */}
      <div
        class="absolute inset-0 bg-[linear-gradient(90deg,var(--color-accent)_0%,color-mix(in_oklab,var(--color-accent)_92%,transparent)_30%,color-mix(in_oklab,var(--color-accent)_55%,transparent)_62%,transparent_100%)]"
        aria-hidden="true"
      >
      </div>

      <div class="container relative z-10 py-[100px]">
        <div class="max-w-[640px] text-bg">
          <span class="section-pretitle !text-bg">Why Choose Us</span>
          <h2 class="section-title !text-bg !text-[clamp(32px,4.5vw,52px)] leading-[1.05] mb-4">
            Ready for a
            <span class="not-italic font-[family-name:var(--font-body)]"> better </span>
            roof?
          </h2>
          <p class="text-bg/90 text-lg leading-relaxed mb-8 max-w-[480px]">
            Our unmatched benefits that set us apart and ensure your peace of mind.
          </p>

          <ul class="flex flex-col gap-5 mb-10">
            {
              whyChoosePoints.map((point, i) => (
                <li class="flex items-center gap-4">
                  <span class="flex-shrink-0 w-7 h-7 rounded-full bg-primary text-bg text-sm font-bold flex items-center justify-center">
                    {i + 1}
                  </span>
                  <span class="text-bg text-lg font-semibold">{point.data.title}</span>
                </li>
              ))
            }
          </ul>

          <div class="flex flex-wrap items-center gap-4">
            <Button variant="gradient" size="lg" href="/contact-us">
              Request an Estimate
            </Button>
            <PhoneLink variant="phone" tone="white" size="lg" />
          </div>
        </div>
      </div>
    </section>

    {/* Contact form — commented out, replaced by the CTA banner above.
    <section class="contact-section" id="quote-form">
      <svg
        class="contact-watermark left-[-50px] top-[10%] rotate-[15deg]"
        viewBox="0 0 100 100"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="M10 90 L50 40 L90 90" stroke="rgba(255,255,255,0.04)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
        <rect x="42" y="70" width="16" height="16" stroke="rgba(255,255,255,0.04)" stroke-width="3" fill="none" />
        <line x1="50" y1="70" x2="50" y2="86" stroke="rgba(255,255,255,0.04)" stroke-width="2" />
        <line x1="42" y1="78" x2="58" y2="78" stroke="rgba(255,255,255,0.04)" stroke-width="2" />
      </svg>
      <svg
        class="contact-watermark right-[-50px] bottom-[5%] rotate-[-15deg]"
        viewBox="0 0 100 100"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="M10 90 L50 40 L90 90" stroke="rgba(255,255,255,0.04)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
        <rect x="42" y="70" width="16" height="16" stroke="rgba(255,255,255,0.04)" stroke-width="3" fill="none" />
        <line x1="50" y1="70" x2="50" y2="86" stroke="rgba(255,255,255,0.04)" stroke-width="2" />
        <line x1="42" y1="78" x2="58" y2="78" stroke="rgba(255,255,255,0.04)" stroke-width="2" />
      </svg>

      <div class="container relative z-[3]">
        <h2 class="contact-title">Request an estimate</h2>
        <form class="max-w-[900px] mx-auto">
