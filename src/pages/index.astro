---
import BaseLayout from "@/layouts/BaseLayout.astro";

import heroWorker from "../assets/images/hero_worker.png";
import serviceGutter from "../assets/images/service_gutter.png";
import serviceRoofInstall from "../assets/images/service_roof_install.png";
import serviceRoofRepair from "../assets/images/service_roof_repair.png";
import serviceRoofReplace from "../assets/images/service_roof_replace.png";
import serviceSiding from "../assets/images/service_siding.png";
import project1Before from "../assets/images/project_1_before.png";
import project1After from "../assets/images/project_1_after.png";
import project2Before from "../assets/images/project_2_before.jpg";
import project2After from "../assets/images/project_2_after.jpg";

import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query, sortByOrder } from "@/utils/query";

import { getPublishedCollection } from "@/utils/collections/core";
const testimonials = await getPublishedCollection("testimonials");
const featuredTestimonials = testimonials.sort((a, b) => (a.data.order || 0) - (b.data.order || 0)).slice(0, 3);
---

<BaseLayout
  title="Professional Roofing Services"
  description="Professional roofing services in Somerset, New Jersey. Free estimates, 0% financing available, roof repairs, replacements, and commercial roofing."
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&family=Saira+Condensed:ital,wght@1,700;1,800&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <main class="flex-1">
    <section class="hero" id="hero">
      <div class="absolute inset-0 z-[1] bg-[linear-gradient(180deg,rgba(15,23,42,0.8)_0%,rgba(15,23,42,0.85)_60%,rgba(15,23,42,0.92)_100%)]"></div>
      <div class="container relative z-[2] flex justify-center">
        <div class="flex flex-col items-center text-center max-w-[900px]">
          <h1 class="font-['Saira_Condensed'] font-extrabold italic leading-[0.9] mb-4 tracking-normal uppercase text-white [text-shadow:0_2px_20px_rgba(0,0,0,0.35)]">
            <span class="hero-title-top">John's Pro</span>
            <span class="hero-title-bottom">Roofing</span>
          </h1>
          <p class="hero-subtitle">
            Free estimates, 0% financing available, and dependable roofing work from a local team you can count on.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="tel:7323513518" class="btn btn-accent btn-large">
              Call Now - 732-351-3518 <i class="fa-solid fa-phone"></i>
            </a>
            <a href="#quote-form" class="btn btn-outline-light btn-large">
              Request an Estimate
            </a>
          </div>

          <a
            href="/testimonials"
            class="inline-flex items-center gap-3 mt-7"
            aria-label="Rated 4.7 out of 5 from 20 Google reviews"
          >
            <svg class="w-[22px] h-[22px] shrink-0" viewBox="0 0 24 24" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.76h3.56c2.08-1.92 3.28-4.74 3.28-8.09Z" />
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.76c-.98.66-2.23 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z" />
              <path fill="#FBBC05" d="M5.84 14.11a6.6 6.6 0 0 1 0-4.22V7.05H2.18a11 11 0 0 0 0 9.9l3.66-2.84Z" />
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.05l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38Z" />
            </svg>
            <span class="inline-flex gap-0.5 text-[#fbbc05] text-[15px] leading-none" aria-hidden="true">
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
            </span>
            <span class="font-['Saira_Condensed'] font-bold text-base text-white leading-none">4.7</span>
            <span class="text-white text-[11px] leading-none" aria-hidden="true">★</span>
            <span class="text-sm font-medium text-white/75 leading-none whitespace-nowrap">20 Reviews</span>
          </a>
        </div>
      </div>
    </section>

    <ContentRenderer
      query={query("selling-points").orderBy(sortByOrder())}
      variant="MarqueeVariant"
    />

    <section class="bg-[var(--color-canvas-secondary)] py-[100px] border-t border-[var(--color-border)]" id="services">
      <div class="container">
        <div class="section-header">
          <span class="section-pretitle">Professional Roofing & Decking</span>
          <h2 class="section-title">Free Estimate Financing Available</h2>
          <p class="section-description">
            We provide residential roofing, commercial roofing, flat roof expertise, and custom decking services with premium materials and a straightforward process.
          </p>
        </div>

        <div class="services-grid">
          {/* Residential Roofing */}
          <div class="service-card">
            <div class="card-image-container">
              <img
                src={serviceRoofInstall.src}
                alt="Residential Roofing Service"
                class="card-image"
              />
              <div class="card-badge">Premium</div>
            </div>
            <div class="card-content">
              <h3 class="card-title">Residential Roofing</h3>
              <p class="card-text">
                Full residential roofing services built for lasting protection and clean, dependable results.
              </p>
              <a href="#quote-form" class="card-link">
                Learn More <i class="fa-solid fa-arrow-right-long"></i>
              </a>
            </div>
          </div>

          {/* Commercial Roofing */}
          <div class="service-card">
            <div class="card-image-container">
              <img
                src={serviceRoofReplace.src}
                alt="Commercial Roofing Service"
                class="card-image"
              />
              <div class="card-badge">Certified</div>
            </div>
            <div class="card-content">
              <h3 class="card-title">Commercial Roofing</h3>
              <p class="card-text">
                Commercial roof replacement and repair work completed with quality materials and careful attention to detail.
              </p>
              <a href="#quote-form" class="card-link">
                Learn More <i class="fa-solid fa-arrow-right-long"></i>
              </a>
            </div>
          </div>

          {/* Flat Roof Experts */}
          <div class="service-card">
            <div class="card-image-container">
              <img
                src={serviceRoofRepair.src}
                alt="Flat Roof Experts"
                class="card-image"
              />
              <div class="card-badge">Expert Solutions</div>
            </div>
            <div class="card-content">
              <h3 class="card-title">Flat Roof Experts</h3>
              <p class="card-text">
                Specialized flat roof installations, durable silicone coatings, and expert repairs for residential and commercial properties.
              </p>
              <a href="#quote-form" class="card-link">
                Learn More <i class="fa-solid fa-arrow-right-long"></i>
              </a>
            </div>
          </div>

          {/* Roof Repair */}
          <div class="service-card">
            <div class="card-image-container">
              <img
                src={serviceRoofRepair.src}
                alt="Roof Repair Service"
                class="card-image"
              />
              <div class="card-badge">24/7 Support</div>
            </div>
            <div class="card-content">
              <h3 class="card-title">Roof Repair</h3>
              <p class="card-text">
                Fast repair service for leaks, storm damage, missing shingles, and flashing issues.
              </p>
              <a href="#quote-form" class="card-link">
                Learn More <i class="fa-solid fa-arrow-right-long"></i>
              </a>
            </div>
          </div>

          {/* Deck Installation */}
          <div class="service-card">
            <div class="card-image-container">
              <img
                src={serviceSiding.src}
                alt="Deck Installation Service"
                class="card-image"
              />
            </div>
            <div class="card-content">
              <h3 class="card-title">Deck Installation</h3>
              <p class="card-text">
                Custom deck builds that create durable outdoor living space.
              </p>
              <a href="#quote-form" class="card-link">
                Learn More <i class="fa-solid fa-arrow-right-long"></i>
              </a>
            </div>
          </div>

          {/* Deck Repair */}
          <div class="service-card">
            <div class="card-image-container">
              <img
                src={serviceGutter.src}
                alt="Deck Repair Service"
                class="card-image"
              />
            </div>
            <div class="card-content">
              <h3 class="card-title">Deck Repair</h3>
              <p class="card-text">
                Repair loose boards, weather damage, and structural wear on existing decks.
              </p>
              <a href="#quote-form" class="card-link">
                Learn More <i class="fa-solid fa-arrow-right-long"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="about-section" id="about">
      <div class="container">
        <div class="text-center max-w-[900px] mx-auto mb-[50px]">
          <h2 class="about-title">John's Pro Roofing LLC</h2>
          <p class="text-[var(--color-text-body)] text-base leading-[1.8] font-normal tracking-[0.1px]">
            No job is too big or too small. Let us help with residential roofing, commercial roofing, and deck work. John's Pro Roofing LLC serves Somerset, New Jersey with straightforward service, honest communication, and dependable results.
          </p>
        </div>
        <div class="about-gallery">
          <div class="about-gallery-item">
            <img src={heroWorker.src} alt="John's Pro Roofing crew on site" />
          </div>
          <div class="about-gallery-item">
            <img
              src={serviceRoofReplace.src}
              alt="Roofing and decking work"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="testimonials-section" id="testimonials">
      <div class="container">
        <div class="section-header">
          <span class="section-pretitle">Reviews</span>
          <h2 class="section-title">4.7 From 20 Reviews</h2>
          <p class="section-description">
            John's Pro Roofing LLC is trusted for responsive service, clean workmanship, and roofing projects completed the right way.
          </p>
        </div>

        <div class="reviews-summary">
          <span class="reviews-score">4.7</span>
          <span class="reviews-brand">John's Pro Roofing LLC</span>
          <span class="reviews-count">· 20 Reviews</span>
        </div>

        <div class="testimonials-marquee" aria-label="Customer testimonials">
          {await (async () => {
            const rendered = await Promise.all(featuredTestimonials.map(async (testimonial) => {
              const { render } = await import("astro:content");
              const { Content } = await render(testimonial);
              return { ...testimonial, Content };
            }));
            // Duplicate the set so the marquee loops seamlessly.
            return [0, 1].map((groupIndex) => (
              <div class="testimonials-marquee-group" aria-hidden={groupIndex === 1 ? "true" : undefined}>
                {rendered.map(({ data, Content }) => {
                  const initial = data.title?.charAt(0).toUpperCase() || '?';
                  return (
                    <div class="testimonial-card">
                      <div class="testimonial-header">
                        <div class="testimonial-avatar-initials">{initial}</div>
                        <div class="testimonial-meta">
                          <span class="testimonial-name">{data.title}</span>
                          <span class="testimonial-role">{data.role}</span>
                        </div>
                      </div>
                      <h3 class="testimonial-heading">{data.description}</h3>
                      <div class="testimonial-text"><Content /></div>
                      <svg
                        class="testimonial-watermark"
                        viewBox="0 0 100 100"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path d="M10 90 L50 40 L90 90" stroke="rgba(255,255,255,0.06)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M25 90 L50 60 L75 90" stroke="rgba(255,255,255,0.04)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                        <rect x="42" y="70" width="16" height="16" stroke="rgba(255,255,255,0.06)" stroke-width="3" fill="none" />
                        <line x1="50" y1="70" x2="50" y2="86" stroke="rgba(255,255,255,0.06)" stroke-width="2" />
                        <line x1="42" y1="78" x2="58" y2="78" stroke="rgba(255,255,255,0.06)" stroke-width="2" />
                      </svg>
                    </div>
                  );
                })}
              </div>
            ));
          })()}
        </div>

        <div class="flex justify-center mt-12">
          <a href="/testimonials" class="btn btn-accent btn-large">
            See More Reviews <i class="fa-solid fa-arrow-right-long ml-2"></i>
          </a>
        </div>
      </div>
    </section>

    <section class="py-[100px] bg-[var(--color-canvas-secondary)] border-t border-b border-[var(--color-border)]" id="projects">
      <div class="container">
        <div class="section-header">
          <span class="section-pretitle">Recent Projects</span>
          <h2 class="section-title">Choose A Contractor With Confidence</h2>
        </div>
        <div class="projects-gallery">
          <div class="project-pair">
            <div class="project-item">
              <span class="project-label before">Before</span>
              <img src={project1Before.src} alt="Project 1 - Before roof replacement" />
            </div>
            <div class="project-item">
              <span class="project-label after">After</span>
              <img src={project1After.src} alt="Project 1 - After roof replacement" />
            </div>
          </div>
          <div class="project-pair">
            <div class="project-item">
              <span class="project-label before">Before</span>
              <img src={project2Before.src} alt="Project 2 - Before roof replacement" />
            </div>
            <div class="project-item">
              <span class="project-label after">After</span>
              <img src={project2After.src} alt="Project 2 - After roof replacement" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="contact-section" id="quote-form">
      <svg
        class="contact-watermark left-[-50px] top-[10%] rotate-[15deg]"
        viewBox="0 0 100 100"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="M10 90 L50 40 L90 90" stroke="rgba(255,255,255,0.04)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
        <rect x="42" y="70" width="16" height="16" stroke="rgba(255,255,255,0.04)" stroke-width="3" fill="none" />
        <line x1="50" y1="70" x2="50" y2="86" stroke="rgba(255,255,255,0.04)" stroke-width="2" />
        <line x1="42" y1="78" x2="58" y2="78" stroke="rgba(255,255,255,0.04)" stroke-width="2" />
      </svg>
      <svg
        class="contact-watermark right-[-50px] bottom-[5%] rotate-[-15deg]"
        viewBox="0 0 100 100"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="M10 90 L50 40 L90 90" stroke="rgba(255,255,255,0.04)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
        <rect x="42" y="70" width="16" height="16" stroke="rgba(255,255,255,0.04)" stroke-width="3" fill="none" />
        <line x1="50" y1="70" x2="50" y2="86" stroke="rgba(255,255,255,0.04)" stroke-width="2" />
        <line x1="42" y1="78" x2="58" y2="78" stroke="rgba(255,255,255,0.04)" stroke-width="2" />
      </svg>

      <div class="container relative z-[3]">
        <h2 class="contact-title">Request an estimate</h2>
        <form class="max-w-[900px] mx-auto">
          <div class="form-grid">
            <div class="form-group">
              <input type="text" placeholder="Name" required class="form-input" />
              <input type="email" placeholder="Email*" required class="form-input" />
            </div>
            <div class="form-group">
              <textarea placeholder="Message" required class="form-input form-textarea"></textarea>
            </div>
          </div>

          <div class="max-w-[900px] mx-auto mb-9">
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="checkbox" required class="w-[18px] h-[18px] accent-[var(--color-accent-red)] mt-[3px] shrink-0" />
              <span class="consent-text">
                This site is protected by reCAPTCHA and the Google Privacy Policy and Terms of Service apply.
              </span>
            </label>
          </div>

          <div class="text-center">
            <button type="submit" class="btn btn-accent btn-large">Submit</button>
          </div>
        </form>
      </div>
    </section>

  </main>
</BaseLayout>
