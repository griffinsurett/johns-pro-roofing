---
// src/layouts/collections/TestimonialsIndexLayout.astro
/**
 * Testimonials Index Layout
 *
 * Renders all reviews using the same design and review card format as the homepage.
 */
import type { CollectionKey } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SecondaryHero from "@/layouts/SecondaryHero.astro";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import GoogleRating from "@/components/GoogleRating.astro";
import { query, sortByOrder } from "@/utils/query";
import { getPublishedCollection } from "@/utils/collections/core";

export interface Props {
  Content?: any;
  collectionName: CollectionKey;
  collectionMeta: any;
  seoProps: any;
  hasContent?: boolean;
  [key: string]: any;
}

const {
  collectionMeta,
  seoProps,
} = Astro.props;

// Count for the reviews-summary badge
const testimonials = await getPublishedCollection("testimonials");
const reviewCount = testimonials.length;
---

<BaseLayout {...seoProps}>
  <main class="flex-1">
    <SecondaryHero
      eyebrow="Reviews"
      title="What Our Customers Say"
      heading={collectionMeta.heading}
      description="John's Pro Roofing LLC is trusted for responsive service, clean workmanship, and roofing projects completed the right way."
      minHeight="40vh"
    />

    <div class="pt-12">
      <div class="container">
        <div class="flex justify-center">
          <GoogleRating tone="light" rating={4.7} count={reviewCount} />
        </div>
      </div>
    </div>

    <ContentRenderer
      query={query("testimonials").orderBy(sortByOrder())}
      variant="TestimonialVariant"
      columns={3}
      showButtonSection={false}
    />
  </main>
</BaseLayout>
