---
// src/layouts/FrontPageHero2.astro
/**
 * Front Page Hero — variation 2 ("fph2")
 *
 * Split background: image on the left half, looping video on the right half.
 * The cut-out "john-pointing" person is absolutely centered over the seam.
 * Text content (heading / subtitle / CTA) overlays the left half with a scrim.
 */
import { Image } from "astro:assets";
import Button from "@/components/Button/Button";
import PhoneLink from "@/components/PhoneLink.astro";
import GoogleRating from "@/components/GoogleRating.astro";
import bgImage from "@/assets/images/service_roof_install.png";
import personImage from "@/assets/john-pointing.png";

export interface Props {
  /** Small kicker above the headline. */
  eyebrow?: string;
  /** Headline lead-in (navy). */
  titleTop?: string;
  /** Headline emphasis (accent red). */
  titleBottom?: string;
  /** Optional text after the emphasis, completing the headline (navy). */
  titleAfter?: string;
  description?: string;
  /** Left-half background image. */
  image?: ImageMetadata;
  /** Right-half background video (public path). */
  video?: string;
  /** Foreground cut-out person, centered. */
  person?: ImageMetadata;
  personAlt?: string;
  primaryCTA?: { text: string; link: string };
  /** Show the Google rating trust row. */
  googleRating?: boolean;
  className?: string;
  id?: string;
}

const {
  eyebrow,
  titleTop = "Your Roof,",
  titleBottom = "Done Right",
  titleAfter = "the First Time.",
  description,
  image = bgImage,
  video = "/placeholder-vid.mp4",
  person = personImage,
  personAlt = "John's Pro Roofing crew member pointing at a finished roof",
  primaryCTA = { text: "Get a Free Quote", link: "/contact-us" },
  googleRating = true,
  className = "",
  id = "hero",
} = Astro.props;
---

<section
  id={id}
  class={`relative overflow-hidden bg-surface lg:min-h-[clamp(560px,85vh,900px)] ${className}`}
>
  {/* ── Background image + white overlay. Covers the full section on desktop;
        on mobile it only fills the top text panel (the video stacks below). ── */}
  <div class="absolute inset-x-0 top-0 bottom-[300px] sm:bottom-[380px] lg:bottom-0">
    <Image
      src={image}
      alt=""
      aria-hidden="true"
      widths={[960, 1280, 1600]}
      sizes="100vw"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    {/* White overlay so the panel reads light for dark text. Mobile uses the
        same opacity range as desktop, just top→bottom instead of left→right. */}
    <div
      class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.95)_0%,rgba(255,255,255,0.9)_45%,rgba(255,255,255,0.82)_100%)] lg:bg-[linear-gradient(90deg,rgba(255,255,255,0.85)_0%,rgba(255,255,255,0.72)_45%,rgba(255,255,255,0.5)_100%)]"
    >
    </div>
  </div>

  {/* Right video panel (lg+), clipped with a slanted left edge */}
  <div class="fph2-video hidden lg:block absolute inset-y-0 right-0 w-[58%]">
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
    >
      <source src={video} type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-primary/15"></div>
  </div>

  {/* Desktop foreground person (lg+), centered over the seam */}
  <Image
    src={person}
    alt={personAlt}
    widths={[480, 720, 960]}
    sizes="40vw"
    class="hidden lg:block absolute bottom-0 left-1/2 -translate-x-1/2 z-[2] h-[92%] w-auto object-contain object-bottom pointer-events-none"
    loading="eager"
    fetchpriority="high"
  />

  {/* ── Content. Desktop: overlaid left. Mobile: stacked text block on top ── */}
  <div class="relative z-[3] w-full max-w-[1600px] mx-auto px-6 lg:px-12">
    <div
      class="flex flex-col justify-center items-start gap-5 max-w-[560px] py-12 lg:py-16 lg:min-h-[clamp(560px,85vh,900px)]"
    >
      {
        eyebrow && (
          <p class="inline-flex items-center text-[13px] font-bold uppercase tracking-[0.18em] text-accent">
            {eyebrow}
          </p>
        )
      }

      <h1
        class="font-display font-extrabold italic uppercase text-heading leading-[1] text-[clamp(32px,4vw,52px)] [text-wrap:balance]"
      >
        <span>{titleTop} </span>
        <span class="not-italic text-accent">{titleBottom}</span>
        {titleAfter && <span> {titleAfter}</span>}
      </h1>

      {
        description && (
          <p class="text-[var(--color-text-muted)] text-base lg:text-lg leading-relaxed max-w-[460px]">
            {description}
          </p>
        )
      }

      <div class="flex flex-wrap items-center gap-4 mt-1">
        {
          primaryCTA && (
            <Button variant="primary" size="lg" href={primaryCTA.link}>
              {primaryCTA.text}
            </Button>
          )
        }
        <PhoneLink variant="phone" tone="blue" size="lg" />
      </div>

      {googleRating && <GoogleRating tone="dark" />}
    </div>
  </div>

  {/* ── Mobile media banner (below lg): video only, no cut-out person ── */}
  <div class="lg:hidden relative w-full h-[300px] sm:h-[380px]">
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
    >
      <source src={video} type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-primary/15"></div>
  </div>
</section>

<style>
  @media (min-width: 1024px) {
    /* Diagonal seam: the video panel's left edge slants. Top-left starts
       further right than the bottom-left, so the cut leans forward. */
    .fph2-video {
      clip-path: polygon(14% 0, 100% 0, 100% 100%, 0 100%);
    }
  }
</style>
