---
// src/layouts/Header.astro
/**
 * Site Header with Navigation
 */
import headerLogo from "@/assets/images/logo.png";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { related } from "@/utils/query";
import { siteData } from "@/content/siteData";
import Button from "@/components/Button/Button";
import PhoneLink from "@/components/PhoneLink.astro";
---

<header class="site-header">
  <div class="header-shell">
    <div class="header-width header-container">
      {/* Nav: desktop inline menu + mobile hamburger (hamburger sits left on mobile) */}
      <div class="header-nav">
        <ContentRenderer
          query={related("menu-items", "menu", "main-menu")}
          variant="MenuVariant"
          mode="responsive"
          className="header-navigation"
          hamburgerTransform={true}
        />
      </div>

      <a href="/" class="logo-link" aria-label={siteData.title}>
        <img src={headerLogo.src} alt={`${siteData.title} logo`} class="brand-logo" />
      </a>

      <div class="header-cta">
        <PhoneLink variant="phone" tone="blue" />
        <Button variant="primary" href="/contact-us">
          Request an Estimate
        </Button>
      </div>
    </div>
  </div>

  {/* Mobile-only action row — red estimate + blue phone, full width */}
  <div class="mobile-action-bar">
    <Button variant="primary" href="/contact-us" className="mobile-action-btn" fullWidth>
      Contact Us
    </Button>
    <PhoneLink variant="phone" tone="blue" class="mobile-action-btn" />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 60;
    box-shadow: 0 1px 0 rgba(5, 24, 48, 0.08);
  }

  .header-width {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 48px;
  }

  .header-shell {
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 90px;
    gap: 24px;
  }

  /* Desktop order: logo, nav, cta (logo on the left as before) */
  .logo-link {
    order: 1;
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .header-nav {
    order: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
  }

  .brand-logo {
    display: block;
    height: 72px;
    width: auto;
    object-fit: contain;
  }

  .header-cta {
    order: 3;
    flex: 1;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 20px;
  }

  /* Mobile action bar — hidden on desktop */
  .mobile-action-bar {
    display: none;
  }

  /* ===== Mobile layout: hamburger left, logo centered, action row below ===== */
  @media (max-width: 1024px) {
    .header-container {
      position: relative;
      justify-content: flex-start;
      padding-top: 32px;
      padding-bottom: 32px;
    }

    /* Hamburger stays at the left */
    .header-nav {
      flex: 0 0 auto;
      z-index: 2;
    }

    /* Logo absolutely centered within the header row, enlarged for mobile */
    .logo-link {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
    }

    .brand-logo {
      height: 92px;
    }

    /* Desktop inline CTA hidden on mobile */
    .header-cta {
      display: none;
    }

    /* Full-width two-button action row */
    .mobile-action-bar {
      display: flex;
      gap: 12px;
      padding: 6px 24px;
      background-color: #fff;
    }

    /* Each button (and its wrapper, if any) fills half the row */
    .mobile-action-bar > :global(*) {
      flex: 1;
    }

    .mobile-action-bar :global(.btn-base) {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .header-width {
      padding: 0 24px;
    }

    .header-container {
      min-height: 80px;
    }

    .brand-logo {
      height: 80px;
    }
  }
</style>
