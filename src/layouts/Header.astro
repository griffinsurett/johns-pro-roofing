---
// src/layouts/Header.astro
/**
 * Site Header with Navigation
 */
import headerLogo from "@/assets/images/logo.png";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { related } from "@/utils/query";
import { siteData } from "@/content/siteData";
---

<header class="site-header">
  <div class="header-shell">
    <div class="header-width header-container">
      <a href="/" class="logo-link" aria-label={siteData.title}>
        <img src={headerLogo.src} alt={`${siteData.title} logo`} class="brand-logo" />
      </a>

      <ContentRenderer
        query={related("menu-items", "menu", "main-menu")}
        variant="MenuVariant"
        mode="responsive"
        className="header-navigation"
        hamburgerTransform={true}
      />

      <div class="header-cta">
        <a href="tel:7323513518" class="header-cta-link">Call Now</a>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 60;
    box-shadow: 0 1px 0 rgba(5, 24, 48, 0.08);
  }

  .header-width {
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 48px;
  }

  .header-shell {
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 90px;
    gap: 24px;
  }

  .logo-link {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .brand-logo {
    display: block;
    height: 72px;
    width: auto;
    object-fit: contain;
  }

  .header-cta {
    flex-shrink: 0;
  }

  .header-cta-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 22px;
    border-radius: 8px;
    background-color: #c8102e;
    color: #fff;
    font-family: Outfit, sans-serif;
    font-size: 15px;
    font-weight: 700;
    box-shadow: 0 4px 12px rgba(200, 16, 46, 0.2);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .header-cta-link:hover {
    background-color: #a60c23;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(200, 16, 46, 0.35);
  }

  @media (max-width: 1024px) {
    .header-cta {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .header-width {
      padding: 0 24px;
    }

    .top-bar-left span {
      display: none;
    }

    .header-container {
      min-height: 72px;
    }

    .brand-logo {
      height: 56px;
    }
  }
</style>
