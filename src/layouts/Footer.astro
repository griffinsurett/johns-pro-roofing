---
// src/layouts/Footer.astro
/**
 * Footer Component
 *
 * Site-wide footer with:
 * - Copyright notice
 * - Social media links
 * - Legal links (Privacy Policy, Cookie Policy)
 * - Cookie preferences button (client-side)
 * - Reading preferences button (client-side)
 */
import { siteData } from "@/content/siteData";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query, related, sortByOrder } from "@/utils/query";
import PreferencesLayout from "./PreferencesLayout.astro";
import { getContactLinks } from "@/utils/contactLinks";
import Icon from "@/components/Icon";
import ReviewButton from "@/components/ReviewButton.astro";
import footerLogo from "@/assets/white-logo.png";

// Contact info, looped straight from the contact-us content collection
const contactLinks = await getContactLinks();
---

<footer class="relative bg-brand-gradient text-bg mt-auto pt-16 border-t border-bg/10 overflow-hidden">
  <div class="w-full max-w-[1600px] mx-auto px-6 lg:px-12 relative z-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 mb-16 text-left">
      
      {/* Column 1: Brand & Contact */}
      <div class="flex flex-col gap-6">
        <a href="/" class="inline-block" aria-label={siteData.title}>
          <img src={footerLogo.src} alt={`${siteData.title} logo`} class="h-28 w-auto" />
        </a>
        <p class="text-bg/80 text-sm leading-relaxed">
          Built on Trust. Roofed for Life.<br/>
          Your trusted local New Jersey roofing professionals.
        </p>
        <ul class="flex flex-col gap-3 text-sm text-bg/80 mt-2 list-none">
          {contactLinks.map((item) => (
            <li>
              <a
                href={item.url}
                class="inline-flex items-start gap-2.5 hover:text-bg transition-colors"
                target={item.url?.startsWith("http") ? "_blank" : undefined}
                rel={item.url?.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                <Icon icon={item.icon || "lu:contact"} size="sm" className="text-bg/70 shrink-0 mt-0.5" />
                <span>{item.displayValue}</span>
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-4">
          <ContentRenderer
            query={query("social-media")}
            variant="SocialMediaVariant"
            size="sm"
            alignment="left"
            className="text-bg"
          />
        </div>

        <ReviewButton class="mt-2" />
      </div>

      {/* Column 2: Roofing Services */}
      <div class="flex flex-col gap-6">
        <h3 class="text-lg font-bold text-bg uppercase tracking-wider">Roofing Services</h3>
        <div class="text-sm text-bg/80">
          <ContentRenderer
            query={query("roofing")
              .where((entry) => Boolean(entry.data.cardSize))
              .orderBy(sortByOrder())}
            variant="ListVariant"
            title=""
            description=""
            showButtonSection={false}
            className="py-0 [&_nav]:flex-col [&_nav]:items-start [&_nav]:gap-3"
          />
        </div>
      </div>

      {/* Column 3: Quick Links */}
      <div class="flex flex-col gap-6">
        <h3 class="text-lg font-bold text-bg uppercase tracking-wider">Quick Links</h3>
        <div class="text-sm text-bg/80">
          <ContentRenderer
            query={related("menu-items", "menu", "footer-menu")}
            variant="ListVariant"
            title=""
            description=""
            className="py-0 [&_nav]:flex-col [&_nav]:items-start [&_nav]:gap-3"
          />
        </div>
      </div>

      {/* Column 4: Legal & Support */}
      <div class="flex flex-col gap-6">
        <h3 class="text-lg font-bold text-bg uppercase tracking-wider">Legal</h3>
        <div class="text-sm text-bg/80">
          <ContentRenderer
            query={query("legal")}
            variant="ListVariant"
            title=""
            description=""
            className="py-0 [&_nav]:flex-col [&_nav]:items-start [&_nav]:gap-3"
          />
        </div>
      </div>

    </div>

  </div>

  {/* Bottom Bar — full-width red band: copyright + credit (left), preferences row (right) */}
  <div class="relative z-10 bg-accent mt-12">
    <div class="w-full max-w-[1600px] mx-auto px-6 lg:px-12 py-4">
      <div class="flex flex-col gap-3 text-sm text-bg/90 lg:flex-row lg:items-center lg:justify-between">
        <p class="text-xs">
          &copy; {new Date().getFullYear()} {siteData.legalName}. All rights reserved. Built by{" "}
          <a
            href="https://griffinswebservices.com"
            target="_blank"
            rel="noopener noreferrer"
            class="font-semibold underline-offset-4 transition hover:underline"
          >
            Griffin&apos;s Web Services
          </a>
        </p>

        <PreferencesLayout
          className="flex flex-wrap items-center justify-start lg:justify-end gap-x-6 gap-y-2"
          buttonClassName="!text-bg/90 hover:!text-bg hover:underline text-xs transition-colors"
        />
      </div>
    </div>
  </div>
</footer>
