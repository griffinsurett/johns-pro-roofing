---
// src/layouts/Footer.astro
/**
 * Footer Component
 *
 * Site-wide footer with:
 * - Copyright notice
 * - Social media links
 * - Legal links (Privacy Policy, Cookie Policy)
 * - Cookie preferences button (client-side)
 * - Reading preferences button (client-side)
 */
import { siteData } from "@/content/siteData";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query, related } from "@/utils/query";
import PreferencesLayout from "./PreferencesLayout.astro";
import { getContactLinks } from "@/utils/contactLinks";
import Icon from "@/components/Icon";
import footerLogo from "@/assets/images/logo.png";
import footerBg from "@/assets/images/project_1_after.png";

// Contact info, looped straight from the contact-us content collection
const contactLinks = await getContactLinks();
---

<footer class="relative text-bg mt-auto pt-16 pb-8 border-t border-bg/10 overflow-hidden">
  {/* Background project photo */}
  <img
    src={footerBg.src}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover"
  />
  {/* Blue brand overlay (reversed navy gradient) */}
  <div
    class="absolute inset-0 bg-[linear-gradient(120deg,var(--color-brand-navy-light)_0%,var(--color-brand-navy)_50%,var(--color-brand-navy-dark)_100%)] opacity-[0.96]"
    aria-hidden="true"
  ></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 mb-16 text-left">
      
      {/* Column 1: Brand & Contact */}
      <div class="flex flex-col gap-6">
        <a href="/" class="inline-block" aria-label={siteData.title}>
          <img src={footerLogo.src} alt={`${siteData.title} logo`} class="h-16 w-auto" />
        </a>
        <p class="text-bg/80 text-sm leading-relaxed">
          Built on Trust. Roofed for Life.<br/>
          Your trusted local New Jersey roofing professionals.
        </p>
        <ul class="flex flex-col gap-3 text-sm text-bg/80 mt-2 list-none">
          {contactLinks.map((item) => (
            <li>
              <a
                href={item.url}
                class="inline-flex items-start gap-2.5 hover:text-bg transition-colors"
                target={item.url?.startsWith("http") ? "_blank" : undefined}
                rel={item.url?.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                <Icon icon={item.icon || "lu:contact"} size="sm" className="text-bg/70 shrink-0 mt-0.5" />
                <span>{item.displayValue}</span>
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-4">
          <ContentRenderer
            query={query("social-media")}
            variant="SocialMediaVariant"
            size="sm"
            alignment="left"
            className="text-bg"
          />
        </div>
      </div>

      {/* Column 2: Quick Links */}
      <div class="flex flex-col gap-6">
        <h3 class="text-lg font-bold text-bg uppercase tracking-wider">Quick Links</h3>
        <div class="flex flex-col gap-3 text-sm text-bg/80">
          <ContentRenderer
            query={related("menu-items", "menu", "footer-menu")}
            variant="ListVariant"
            className="flex-col items-start gap-4 py-0"
          />
        </div>
      </div>

      {/* Column 3: Legal & Support */}
      <div class="flex flex-col gap-6">
        <h3 class="text-lg font-bold text-bg uppercase tracking-wider">Legal</h3>
        <div class="flex flex-col gap-3 text-sm text-bg/80">
          <ContentRenderer
            query={query("legal")}
            variant="ListVariant"
            className="flex-col items-start gap-4 py-0"
            title=""
          />
        </div>
      </div>

      {/* Column 4: Preferences */}
      <div class="flex flex-col gap-6">
        <h3 class="text-lg font-bold text-bg uppercase tracking-wider">Preferences</h3>
        <div class="w-full flex flex-col items-start text-left">
          <PreferencesLayout buttonClassName="!text-bg/80 hover:!text-bg hover:underline text-sm transition-colors !text-left" />
        </div>
      </div>

    </div>

    {/* Bottom Bar: Copyright */}
    <div class="pt-8 border-t border-bg/10 text-center">
      <p class="text-bg/50 text-xs">
        &copy; {new Date().getFullYear()} {siteData.legalName}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
