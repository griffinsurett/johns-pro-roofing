---
// src/layouts/SecondaryHero.astro
/**
 * Secondary Hero — interior page hero, styled to match the John's Pro Roofing
 * brand (mirrors the homepage FrontPageHero2 pattern):
 *  - brand image background with a white left-light gradient overlay so the
 *    panel reads light for dark navy text (NOT a black scrim)
 *  - accent-red eyebrow + navy extrabold italic uppercase headline
 *    (the same `.section-title` treatment used across the site)
 *  - optional post metadata row (date / author / reading time)
 *
 * Used by every collection item & index layout, so restyling here rebrands all
 * interior page heroes at once.
 */

import { Image } from "astro:assets";
import { getAuthorName } from "@/layouts/collections/helpers/layoutHelpers";
import defaultImage from "@/assets/images/service_roof_install.png";

type Heading = string | { before?: string; text?: string; after?: string };

export interface Props {
  title: string;
  /** Main H1 override — the sought-after heading. Falls back to `title`.
   *  Supports a segmented form `{ before, text, after }` where `text` is the
   *  accent-red emphasis. */
  heading?: Heading;
  eyebrow?: string;
  description?: string;
  image?: any; // Astro image asset or public path
  publishDate?: Date | string;
  author?: string | { collection: string; id: string };
  readingTime?: number;
  className?: string;
  minHeight?: string;
}

const {
  title,
  heading,
  eyebrow,
  description,
  image,
  publishDate,
  author,
  readingTime,
  className = "",
  minHeight = "clamp(360px,52vh,560px)",
} = Astro.props;

const bg = image || defaultImage;
const hasMeta = Boolean(publishDate || author || readingTime);

// The H1 prefers `heading` (string or segmented) and falls back to `title`.
const headingObj =
  heading && typeof heading === "object" ? heading : undefined;
const headingStr =
  typeof heading === "string" && heading.trim() ? heading : undefined;
---

<section
  class={`relative overflow-hidden bg-surface ${className}`}
  style={`min-height: ${minHeight}`}
>
  {/* Brand image background + white left-light gradient (reads light for dark text) */}
  <div class="absolute inset-0">
    {
      typeof bg === "string" ? (
        <img
          src={bg}
          alt=""
          aria-hidden="true"
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
        />
      ) : (
        <Image
          src={bg}
          alt=""
          aria-hidden="true"
          widths={[960, 1280, 1600]}
          sizes="100vw"
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
      )
    }
    <div
      class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.97)_0%,rgba(255,255,255,0.94)_55%,rgba(255,255,255,0.88)_100%)] lg:bg-[linear-gradient(90deg,rgba(255,255,255,0.98)_0%,rgba(255,255,255,0.92)_55%,rgba(255,255,255,0.78)_100%)]"
    >
    </div>
  </div>

  {/* Content — left-aligned, matching the homepage hero */}
  <div
    class="relative z-10 container flex flex-col justify-center items-start gap-4 py-16 lg:py-20"
    style={`min-height: ${minHeight}`}
  >
    {eyebrow && <span class="section-pretitle">{eyebrow}</span>}

    <h1
      class="section-title !mb-0 !text-[clamp(36px,6vw,56px)] leading-[1.05] [text-wrap:balance]"
    >
      {
        headingObj ? (
          <>
            {headingObj.before && <span>{headingObj.before} </span>}
            {headingObj.text && (
              <span class="not-italic text-accent">{headingObj.text}</span>
            )}
            {headingObj.after && <span> {headingObj.after}</span>}
          </>
        ) : (
          headingStr ?? title
        )
      }
    </h1>

    {
      description && (
        <p class="text-[var(--color-text-muted)] text-lg leading-relaxed max-w-[560px] mt-1">
          {description}
        </p>
      )
    }

    {
      hasMeta && (
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 mt-3 text-sm font-medium text-[var(--color-text-muted)]">
          {publishDate && (
            <time
              datetime={new Date(publishDate).toISOString()}
              class="flex items-center gap-2"
            >
              <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {new Date(publishDate).toLocaleDateString()}
            </time>
          )}

          {author && (
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              By {getAuthorName(author)}
            </span>
          )}

          {readingTime && (
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {readingTime} min read
            </span>
          )}
        </div>
      )
    }
  </div>

  {/* Optional slot for additional content below hero */}
  <slot />
</section>
