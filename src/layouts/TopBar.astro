---
// src/layouts/TopBar.astro
/**
 * Top utility bar — sits above the site header.
 * Navy gradient strip: brand message on the left, phone on the right.
 * Service-area states are pulled from the service-areas collection.
 */
import FlagStarIcon from "@/components/FlagStarIcon.astro";
import PhoneLink from "@/components/PhoneLink.astro";
import { getServiceAreaAbbrs } from "@/utils/serviceAreas";

const areaLabel = await getServiceAreaAbbrs(); // "NJ, NY & PA"
---

<div class="top-bar">
  <div class="top-bar-inner">
    <p class="top-bar-message">
      <FlagStarIcon class="top-bar-star" />
      Protecting Homes Across {areaLabel} — One Roof At A Time
    </p>
    <div class="top-bar-phone">
      <PhoneLink variant="phone" tone="white" size="sm" />
    </div>
  </div>
</div>

<style>
  .top-bar {
    /* Scrolls away with the page; the header below is the sticky element. */
    position: relative;
    z-index: 1;
    background: linear-gradient(
      120deg,
      var(--color-brand-navy-dark) 0%,
      var(--color-brand-navy) 50%,
      var(--color-brand-navy-light) 100%
    );
    padding-block: 8px;
  }

  /* Match the header's gutter exactly: max-width 1600px, 48px sides (24px mobile). */
  .top-bar-inner {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    padding-inline: 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .top-bar-message {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin: 0;
    color: #fff;
    font-family: var(--font-family-headings);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .top-bar-message :global(.top-bar-star) {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
    color: #fff;
    opacity: 0.9;
  }

  .top-bar-phone {
    flex-shrink: 0;
  }

  @media (max-width: 767px) {
    /* Match the header's mobile gutter */
    .top-bar-inner {
      padding-inline: 24px;
    }
    /* On phones, drop the phone link and shrink the message */
    .top-bar-phone {
      display: none;
    }
    .top-bar-message {
      font-size: 12px;
      justify-content: center;
      width: 100%;
      text-align: center;
    }
  }
</style>
