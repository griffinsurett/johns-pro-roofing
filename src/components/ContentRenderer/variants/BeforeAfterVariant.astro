---
// src/components/ContentRenderer/variants/BeforeAfterVariant.astro
/**
 * Before/After Variant — grid of stacked before/after project cards.
 * Loops queried projects through BeforeAfterCard (Koi-style stacked design).
 */
import type { BaseVariantProps } from "../ContentRenderer.types";
import BeforeAfterCard from "@/components/LoopComponents/BeforeAfterCard.astro";
import Button from "@/components/Button/Button";
import { shouldShowCollectionCTA } from "../utils/helpers";

interface Props extends BaseVariantProps {
  columns?: 1 | 2 | 3 | 4;
  pretitle?: string;
  accentTitle?: string; // italic accent second line
  dark?: boolean;
}

const {
  items = [],
  title,
  description,
  className = "",
  columns = 3,
  collectionUrl,
  collectionTitle,
  showButtonSection = true,
  pretitle = "Recent Projects",
  accentTitle,
  dark = false,
  id,
} = Astro.props as Props;

const safeItems = Array.isArray(items) ? items : [];

const columnClasses = {
  1: "grid-cols-1",
  2: "grid-cols-1 md:grid-cols-2",
  3: "grid-cols-1 md:grid-cols-2 lg:grid-cols-3",
  4: "grid-cols-1 md:grid-cols-2 lg:grid-cols-4",
};
---

<section id={id} class={`py-[100px] ${dark ? "bg-primary" : ""} ${className}`}>
  <div class="container">
    {(title || description) && (
      <div class="section-header">
        {pretitle && <span class="section-pretitle">{pretitle}</span>}
        {title && (
          <h2 class={`section-title ${dark ? "!text-bg" : ""}`}>
            {title}{accentTitle && (
              <span class="italic font-[family-name:var(--font-body)] text-accent normal-case"> {accentTitle}</span>
            )}
          </h2>
        )}
        {description && (
          <p class={`section-description ${dark ? "!text-white/70" : ""}`}>{description}</p>
        )}
      </div>
    )}

    {safeItems.length > 0 && (
      <ul class={`grid ${columnClasses[columns]} gap-[30px] list-none`}>
        {safeItems.map((item) => (
          <li>
            <BeforeAfterCard {...item} />
          </li>
        ))}
      </ul>
    )}

    {showButtonSection && shouldShowCollectionCTA(collectionUrl, safeItems.length) && (
      <div class="flex justify-center mt-12">
        <Button variant="primary" size="lg" href={collectionUrl} rightIcon="lu:arrow-right">
          {`View All ${collectionTitle || "Projects"}`.trim()}
        </Button>
      </div>
    )}
  </div>
</section>
