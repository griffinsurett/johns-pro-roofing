---
// src/components/FlagStarIcon.astro
/**
 * FlagStarIcon — the decorative brand star.
 *
 * Used anywhere a non-rating star appears (top bar service line, marquee
 * dividers, etc.). Solid 5-point star colored via `currentColor`, so the
 * surrounding text color controls it. Decorative by default (aria-hidden).
 *
 * @example
 *   <FlagStarIcon class="w-3 h-3 text-white" />
 */
export interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props as Props;
---

<svg
  class={`flag-star ${className}`}
  viewBox="0 0 24 24"
  fill="currentColor"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path d="M12 2l2.94 5.96 6.58.96-4.76 4.64 1.12 6.55L12 17.77l-5.88 3.09 1.12-6.55L2.48 8.92l6.58-.96L12 2z" />
</svg>

<style>
  /* Sensible default size so the star is never invisible; callers override. */
  .flag-star {
    width: 1em;
    height: 1em;
    display: inline-block;
  }
</style>
