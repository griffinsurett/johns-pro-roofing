---
// src/components/LoopComponents/TestimonialCard.astro
/**
 * Testimonial Card — single customer review card.
 *
 * Consumes a prepared collection item (title = reviewer name, description =
 * short headline, role, plus the raw review body in `content`). Used by
 * TestimonialVariant.
 */

import { Image } from "astro:assets";
import roofMark from "@/assets/roof-from-logo-white.png";
import { siteData } from "@/content/siteData";

export interface Props {
  title: string;
  description?: string;
  role?: string;
  content?: string;
  source?: string;
}

const { title, description, role, content, source } = Astro.props as Props;
const initial = title?.charAt(0).toUpperCase() || "?";
const isGoogle = source === "google";

// Multi-color Google "G" — shown top-right on Google-sourced reviews.
const googleSvg = `<svg width="26" height="26" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-label="Google review"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>`;

// Truncate long reviews; "Read more" links to the Google reviews profile.
const MAX_CHARS = 280;
const plain = (content ?? "").trim();
const isLong = plain.length > MAX_CHARS;
const displayText = isLong
  ? plain.slice(0, MAX_CHARS).replace(/\s+\S*$/, "") + "…"
  : plain;
const reviewsUrl = siteData.googleReviewsUrl;
---

<div class="testimonial-card">
  {isGoogle && (
    <span class="testimonial-google" aria-hidden="true" set:html={googleSvg} />
  )}
  <div class="testimonial-header">
    <div class="testimonial-avatar-initials">{initial}</div>
    <div class="testimonial-meta">
      <span class="testimonial-name">{title}</span>
      {role && <span class="testimonial-role">{role}</span>}
    </div>
  </div>

  {description && <h3 class="testimonial-heading">{description}</h3>}

  {displayText && (
    <div class="testimonial-text">
      {displayText}
      {isLong && reviewsUrl && (
        <a
          href={reviewsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="testimonial-readmore"
        >
          Read more
        </a>
      )}
    </div>
  )}

  <Image
    src={roofMark}
    alt=""
    aria-hidden="true"
    class="testimonial-watermark"
    widths={[160, 320]}
  />
</div>
