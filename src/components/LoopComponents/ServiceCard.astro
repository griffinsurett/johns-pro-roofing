---
// src/components/LoopComponents/ServiceCard.astro
/**
 * Service Card — single service tile (roofing / additional services).
 *
 * Consumes a prepared collection item (title, description, resolved `url`,
 * and `featuredImage`). Renders the John's Pro Roofing `.service-card` design.
 */

export interface Props {
  title: string;
  description?: string;
  url?: string;
  featuredImage?: any;
  badge?: string;
  ctaText?: string;
}

const {
  title,
  description,
  url,
  featuredImage,
  badge,
  ctaText = "Learn More",
} = Astro.props as Props;

// Resolve the Astro image object (or string) to a usable src.
const imgSrc =
  typeof featuredImage === "string"
    ? featuredImage
    : (featuredImage?.src?.src ?? featuredImage?.src ?? "");

const Tag = url ? "a" : "div";
---

<Tag href={url} class="service-card">
  <div class="card-image-container">
    {imgSrc && <img src={imgSrc} alt={title} class="card-image" />}
    {badge && <div class="card-badge">{badge}</div>}
  </div>
  <div class="card-content">
    <h3 class="card-title">{title}</h3>
    {description && <p class="card-text">{description}</p>}
    <span class="card-link">
      {ctaText} <i class="fa-solid fa-arrow-right-long"></i>
    </span>
  </div>
</Tag>
