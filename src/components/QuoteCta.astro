---
// src/components/QuoteCta.astro
/**
 * QuoteCta — conversion section for service pages: the CtaBanner's pitch
 * (photo + red gradient, selling-points, phone) on the left, with the wired
 * QuoteForm embedded on the right so visitors convert in place (no page jump).
 *
 * Drop-in replacement for <CtaBanner /> on service pages. Reuses the same
 * `cta` frontmatter shape, so a page's existing `cta:` block drives the copy.
 */
import PhoneLink from "@/components/PhoneLink.astro";
import QuoteForm from "@/components/Form/forms/QuoteForm.astro";
import ContactForm from "@/components/Form/forms/ContactForm.astro";
import TestimonialCard from "@/components/LoopComponents/TestimonialCard.astro";
import { query, sortByOrder } from "@/utils/query";
import { getCollectionMeta, prepareCollectionEntries } from "@/utils/collections";
import type { CollectionEntry } from "astro:content";
import type { CTAData } from "@/content/schema";
import serviceRoofRepair from "@/assets/images/service_roof_repair.png";

interface Props {
  id?: string;
  cta?: CTAData;
  /** Which form to embed: the short quote form (default) or the full contact form (adds a message field). */
  form?: "quote" | "contact";
  /** Heading above the embedded form panel. */
  formTitle?: string;
  /** Subtext under the form-panel heading. */
  formDescription?: string;
}

const {
  id = "quote-form",
  cta = {},
  form = "quote",
  formTitle = "Request a free estimate",
  formDescription = "No cost, no obligation — we'll be in touch fast.",
} = Astro.props as Props;
const Form = form === "contact" ? ContactForm : QuoteForm;

const title = cta?.title ?? "Ready for a";
const accent = cta?.accent ?? "better";
const titleAfter = cta?.titleAfter ?? "roof?";
const description =
  cta?.description ??
  "Tell us about your project and we'll get you a free, no-obligation estimate.";

// Social proof: real reviews next to the form to maximize conversions.
// Prepared so TestimonialCard gets the review body (`content`).
const testimonialMeta = getCollectionMeta("testimonials");
const testimonialEntries = (await query("testimonials")
  .orderBy(sortByOrder())
  .all()) as CollectionEntry<"testimonials">[];
const testimonials = await prepareCollectionEntries(
  testimonialEntries,
  "testimonials",
  testimonialMeta,
);
// Duplicate the set so the vertical marquee loops seamlessly (translateY -50%).
const loopTestimonials = [...testimonials, ...testimonials];
---

<section class="relative overflow-hidden" id={id}>
  {/* Background photo */}
  <img
    src={serviceRoofRepair.src}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover"
  />
  {/* Red gradient overlay: opaque left → transparent right */}
  <div
    class="absolute inset-0 bg-[linear-gradient(90deg,var(--color-accent)_0%,color-mix(in_oklab,var(--color-accent)_92%,transparent)_45%,color-mix(in_oklab,var(--color-accent)_70%,transparent)_80%,color-mix(in_oklab,var(--color-accent)_55%,transparent)_100%)]"
    aria-hidden="true"
  >
  </div>

  <div class="container relative z-10 py-[80px]">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-center lg:gap-16">
      {/* Pitch */}
      <div class="text-bg">
        <h2 class="section-title !text-bg !text-[clamp(32px,4.5vw,52px)] leading-[1.05] mb-4">
          {title}
          <span class="not-italic font-[family-name:var(--font-body)]"> {accent} </span>
          {titleAfter}
        </h2>
        <p class="text-bg/90 text-lg leading-relaxed mb-8 max-w-[480px]">
          {description}
        </p>

        {
          testimonials.length > 0 && (
            <div
              class="qc-testimonials mb-8"
              aria-label="Customer testimonials"
            >
              <ul class="qc-testimonials-track">
                {loopTestimonials.map((item, i) => (
                  <li
                    class="qc-testimonials-item"
                    aria-hidden={i >= testimonials.length ? "true" : undefined}
                  >
                    <TestimonialCard {...item} />
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        <div class="flex items-center gap-3 text-bg">
          <span class="text-bg/80">Prefer to call?</span>
          <PhoneLink variant="phone" tone="white" size="lg" />
        </div>
      </div>

      {/* Quote form */}
      <div class="bg-bg rounded-2xl shadow-xl p-6 md:p-8">
        <h3 class="text-2xl font-bold text-heading mb-1">{formTitle}</h3>
        <p class="text-text mb-6">{formDescription}</p>
        <Form />
      </div>
    </div>
  </div>
</section>

<style>
  /* Vertical auto-scrolling testimonial marquee beside the form. */
  .qc-testimonials {
    position: relative;
    height: 360px;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(180deg, transparent, #000 12%, #000 88%, transparent);
    mask-image: linear-gradient(180deg, transparent, #000 12%, #000 88%, transparent);
  }
  .qc-testimonials-track {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 0;
    padding: 0;
    list-style: none;
    animation: qc-testimonials-scroll 40s linear infinite;
  }
  .qc-testimonials:hover .qc-testimonials-track {
    animation-play-state: paused;
  }
  .qc-testimonials-item {
    flex: 0 0 auto;
  }
  /* Cards keep their own (light) look so they pop on the red panel. */
  .qc-testimonials-item :global(.testimonial-card) {
    height: 100%;
  }
  @keyframes qc-testimonials-scroll {
    from { transform: translateY(0); }
    to   { transform: translateY(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .qc-testimonials-track {
      animation: none;
    }
  }
</style>
