---
// src/components/GoogleRating.astro
/**
 * GoogleRating — the Google "G" + stars + rating + review count badge.
 * Links to the Google reviews profile. Used in the hero (dark) and the
 * testimonials section (light) via the `tone` prop.
 */
import { siteData } from "@/content/siteData";

interface Props {
  rating?: number;
  count?: number;
  tone?: "light" | "dark"; // dark = for dark backgrounds (white text)
  class?: string;
}

const {
  rating = 4.7,
  count = 20,
  tone = "dark",
  class: className = "",
} = Astro.props as Props;

const href = (siteData as any).googleReviewsUrl ?? "/testimonials";
const isExternal = href.startsWith("http");
const numberClass = tone === "dark" ? "text-white" : "text-primary";
const countClass = tone === "dark" ? "text-white/75" : "text-text-muted";
---

<a
  href={href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noopener noreferrer" : undefined}
  class={`inline-flex items-center gap-3 ${className}`}
  aria-label={`Rated ${rating} out of 5 from ${count} Google reviews`}
>
  <span class={`text-sm font-medium leading-none whitespace-nowrap ${countClass}`}>{count} Reviews</span>
  <svg class="w-[22px] h-[22px] shrink-0" viewBox="0 0 24 24" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.76h3.56c2.08-1.92 3.28-4.74 3.28-8.09Z" />
    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.76c-.98.66-2.23 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z" />
    <path fill="#FBBC05" d="M5.84 14.11a6.6 6.6 0 0 1 0-4.22V7.05H2.18a11 11 0 0 0 0 9.9l3.66-2.84Z" />
    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.05l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38Z" />
  </svg>
  <span class="inline-flex gap-0.5 text-[#fbbc05] text-[15px] leading-none" aria-hidden="true">
    <i class="fa-solid fa-star"></i>
    <i class="fa-solid fa-star"></i>
    <i class="fa-solid fa-star"></i>
    <i class="fa-solid fa-star"></i>
    <i class="fa-solid fa-star"></i>
  </span>
  <span class={`font-['Saira_Condensed'] font-bold text-base leading-none ${numberClass}`}>{rating}</span>
</a>
